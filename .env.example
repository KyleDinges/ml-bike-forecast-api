# Optional non-secret runtime configuration. Docker only loads this file when
# started with: docker run --env-file .env ...
# DEBUG, INFO, WARNING, ERROR, or CRITICAL. Invalid or blank values use INFO.
LOG_LEVEL=INFO
DRIFT_MIN_BATCH_SIZE=30
DRIFT_PSI_WATCH_THRESHOLD=0.10
DRIFT_PSI_ALERT_THRESHOLD=0.25
